{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hiivmind/hiivmind-blueprint-lib/main/schema/runtime/logging.json",
  "title": "Workflow Execution Log",
  "description": "Defines the structure of workflow execution logs produced by log_entry and log_node consequences.",
  "type": "object",
  "properties": {
    "node_history": {
      "type": "array",
      "description": "Chronological record of node executions (produced by log_node)",
      "items": {
        "$ref": "#/$defs/nodeEntry"
      }
    },
    "entries": {
      "type": "array",
      "description": "Log entries at various severity levels (produced by log_entry)",
      "items": {
        "$ref": "#/$defs/logEntry"
      }
    }
  },
  "required": ["node_history", "entries"],
  "$defs": {
    "nodeOutcome": {
      "type": "string",
      "description": "Individual node execution outcome",
      "enum": ["success", "skipped", "error", "blocked"]
    },
    "nodeEntry": {
      "type": "object",
      "description": "Record of a single node execution (from log_node consequence)",
      "properties": {
        "node": {
          "type": "string",
          "description": "Name of the node that was executed"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO8601 timestamp when the node executed"
        },
        "outcome": {
          "$ref": "#/$defs/nodeOutcome"
        },
        "details": {
          "type": "object",
          "description": "Additional node-specific execution details",
          "additionalProperties": true
        }
      },
      "required": ["node", "timestamp", "outcome"]
    },
    "logLevel": {
      "type": "string",
      "description": "Severity level for log entries",
      "enum": ["debug", "info", "warning", "error"]
    },
    "logEntry": {
      "type": "object",
      "description": "A log entry produced by the log_entry consequence",
      "properties": {
        "level": {
          "$ref": "#/$defs/logLevel"
        },
        "message": {
          "type": "string",
          "description": "Human-readable log message"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO8601 timestamp when the entry was logged"
        },
        "node": {
          "type": "string",
          "description": "Node where the entry was logged"
        },
        "context": {
          "type": "object",
          "description": "Additional structured context",
          "additionalProperties": true
        }
      },
      "required": ["level", "message", "timestamp"]
    }
  }
}

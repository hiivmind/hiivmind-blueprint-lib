{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hiivmind/hiivmind-blueprint-lib/main/schema/authoring/workflow.json",
  "$comment": "Schema version 3.0 - Removed definitions block (types now local via .hiivmind/blueprint/definitions.yaml)",
  "title": "Blueprint Workflow Schema",
  "description": "JSON Schema for hiivmind-blueprint workflow.yaml files",
  "type": "object",
  "required": ["name", "version", "start_node", "nodes", "endings"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Workflow name (used as identifier)"
    },
    "version": {
      "$ref": "../common.json#/$defs/semver"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the workflow's purpose"
    },
    "entry_preconditions": {
      "type": "array",
      "items": {
        "$ref": "node-types.json#/$defs/precondition"
      },
      "description": "Conditions that must be true before workflow can start"
    },
    "initial_state": {
      "type": "object",
      "description": "Initial state values when workflow begins. Note: Some fields are computed at runtime and not declared here - see $comment for details.",
      "$comment": "Runtime fields (computed at initialization, not declared): interface (string: 'claude_code' or 'claude_ai' based on AskUserQuestion tool availability), workflow_name, workflow_version, current_node, previous_node, history, user_responses, checkpoints, awaiting_input",
      "properties": {
        "phase": { "type": "string" },
        "flags": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "computed": { "type": "object" },
        "output": {
          "$ref": "../config/output-config.json#/$defs/outputConfig",
          "description": "Unified output configuration (logging + display). Extracted by engine in Phase 2, Step 2.2."
        },
        "prompts": {
          "$ref": "../config/prompts-config.json#/$defs/promptsConfig",
          "description": "User prompt execution mode configuration. Extracted by engine in Phase 2, Step 2.3."
        }
      },
      "additionalProperties": true
    },
    "imports": {
      "type": "object",
      "description": "External YAML files to load at workflow start",
      "additionalProperties": { "type": "string" }
    },
    "start_node": {
      "$ref": "../common.json#/$defs/node_reference",
      "description": "ID of the first node to execute"
    },
    "nodes": {
      "type": "object",
      "description": "Map of node IDs to node definitions",
      "additionalProperties": {
        "$ref": "node-types.json#/$defs/node"
      }
    },
    "endings": {
      "type": "object",
      "description": "Map of ending IDs to ending definitions",
      "additionalProperties": {
        "$ref": "#/$defs/ending"
      }
    }
  },
  "$defs": {
    "ending": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["success", "failure", "error", "cancelled", "indeterminate"],
          "description": "Ending outcome type"
        },
        "category": {
          "type": "string",
          "description": "Optional categorization for error endings (e.g., 'safety', 'validation', 'configuration', 'permission', 'external')"
        },
        "message": {
          "type": "string",
          "description": "Message to display (supports ${} interpolation)"
        },
        "summary": {
          "type": "object",
          "description": "Summary data to display",
          "additionalProperties": true
        },
        "details": {
          "type": "string",
          "description": "Additional details for error endings"
        },
        "recovery": {
          "description": "Recovery guidance for error endings. Can be a simple string or structured object.",
          "oneOf": [
            {
              "type": "string",
              "description": "Simple recovery suggestion text"
            },
            {
              "type": "object",
              "description": "Structured recovery guidance",
              "properties": {
                "suggestion": {
                  "type": "string",
                  "description": "Human-readable recovery suggestion"
                },
                "related_skill": {
                  "type": "string",
                  "description": "Skill to suggest for recovery"
                },
                "retry_node": {
                  "type": "string",
                  "description": "Node to retry from"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "consequences": {
          "type": "array",
          "description": "Consequence operations to execute before completing. Failures are logged but do not prevent completion.",
          "items": {
            "$ref": "node-types.json#/$defs/consequence"
          }
        },
        "behavior": {
          "description": "Terminal behavior. Defaults to display (show message/summary) when omitted.",
          "oneOf": [
            {
              "type": "object",
              "description": "Delegate execution to another skill",
              "required": ["type", "skill"],
              "properties": {
                "type": {
                  "const": "delegate"
                },
                "skill": {
                  "type": "string",
                  "description": "Skill to invoke (supports ${} interpolation)"
                },
                "args": {
                  "type": "string",
                  "description": "Arguments to pass (supports ${} interpolation)"
                },
                "context": {
                  "type": "object",
                  "description": "Context object to pass (values support ${} interpolation)",
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            },
            {
              "type": "object",
              "description": "Restart the workflow from a target node",
              "required": ["type"],
              "properties": {
                "type": {
                  "const": "restart"
                },
                "target_node": {
                  "$ref": "../common.json#/$defs/node_reference",
                  "description": "Node to restart from (defaults to workflow start_node)"
                },
                "reset_state": {
                  "type": "boolean",
                  "description": "Whether to reset state to initial_state (preserves _restart_count)",
                  "default": false
                },
                "max_restarts": {
                  "type": "integer",
                  "description": "Maximum restart iterations before forcing failure",
                  "default": 3,
                  "minimum": 1
                }
              },
              "additionalProperties": false
            },
            {
              "type": "object",
              "description": "Complete silently with no output",
              "required": ["type"],
              "properties": {
                "type": {
                  "const": "silent"
                }
              },
              "additionalProperties": false
            }
          ]
        }
      }
    }
  }
}

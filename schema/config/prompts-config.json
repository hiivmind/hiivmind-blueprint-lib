{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hiivmind/hiivmind-blueprint-lib/main/schema/prompts-config.json",
  "$comment": "Schema version 3.0 - Simplified user prompt configuration",
  "title": "Blueprint Prompts Configuration",
  "description": "Schema for configuring user-prompt node execution. Supports interactive mode (AskUserQuestion tool) and tabular mode (markdown table with text matching).",
  "type": "object",
  "properties": {
    "prompts": {
      "$ref": "#/$defs/promptsConfig"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "promptsConfig": {
      "type": "object",
      "description": "Prompts configuration for user_prompt node execution",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Prompt execution mode",
          "enum": ["interactive", "tabular"],
          "default": "interactive"
        },
        "tabular": {
          "$ref": "#/$defs/tabularConfig"
        }
      },
      "additionalProperties": false
    },
    "tabularConfig": {
      "type": "object",
      "description": "Configuration for tabular mode (markdown table with text matching)",
      "properties": {
        "match_strategy": {
          "type": "string",
          "description": "How to match user text input to option IDs",
          "enum": ["exact", "prefix", "fuzzy"],
          "default": "prefix"
        },
        "other_handler": {
          "type": "string",
          "description": "What to do when user input doesn't match any option",
          "enum": ["prompt", "route", "fail"],
          "default": "prompt"
        },
        "fuzzy_threshold": {
          "type": "number",
          "description": "Similarity threshold for fuzzy matching (0.0-1.0)",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.7
        },
        "case_sensitive": {
          "type": "boolean",
          "description": "Whether matching is case-sensitive",
          "default": false
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "prompts": {
        "mode": "interactive"
      }
    },
    {
      "prompts": {
        "mode": "tabular",
        "tabular": {
          "match_strategy": "prefix",
          "other_handler": "prompt"
        }
      }
    },
    {
      "prompts": {
        "mode": "tabular",
        "tabular": {
          "match_strategy": "fuzzy",
          "fuzzy_threshold": 0.7,
          "other_handler": "route"
        }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hiivmind/hiivmind-blueprint-lib/main/schema/definitions/type-definition.json",
  "$comment": "Unified type definition schema - consequence, precondition, and node definitions",
  "title": "Type Definition Schema",
  "description": "Unified schema for all YAML type definition files (consequences, preconditions, nodes)",
  "oneOf": [
    { "$ref": "#/$defs/consequenceFile" },
    { "$ref": "#/$defs/preconditionFile" },
    { "$ref": "#/$defs/nodeFile" }
  ],
  "$defs": {

    "consequenceFile": {
      "type": "object",
      "required": ["schema_version", "category", "description", "consequences"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "$ref": "../common.json#/$defs/semver_short" },
        "category": { "$ref": "../common.json#/$defs/category_path" },
        "description": { "type": "string" },
        "consequences": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/consequence" }
        }
      }
    },

    "consequence": {
      "type": "object",
      "required": ["category", "description", "parameters", "payload"],
      "additionalProperties": false,
      "properties": {
        "category": { "$ref": "../common.json#/$defs/category_path" },
        "description": { "$ref": "#/$defs/typeDescription" },
        "parameters": {
          "type": "array",
          "items": { "$ref": "../common.json#/$defs/parameter" }
        },
        "payload": { "$ref": "#/$defs/payload" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/consequenceExample" }
        },
        "related": {
          "type": "array",
          "items": { "type": "string" }
        },
        "since": { "$ref": "../common.json#/$defs/semver" },
        "replaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "payload": {
      "type": "object",
      "required": ["kind", "effect"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["state_mutation", "tool_call", "computation", "side_effect", "composite"]
        },
        "tool": {
          "type": ["string", "null"],
          "description": "Claude tool name if tool_call kind"
        },
        "effect": {
          "type": "string",
          "description": "Pseudocode describing the operation"
        },
        "state_writes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "state_reads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requires": { "$ref": "#/$defs/requires" },
        "execution": { "$ref": "#/$defs/consequenceExecution" },
        "provides": { "$ref": "#/$defs/provides" },
        "alternatives": {
          "type": "array",
          "items": { "$ref": "#/$defs/alternative" }
        },
        "script": { "$ref": "#/$defs/script" }
      }
    },

    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolRequirement" }
        },
        "shell": {
          "type": "string",
          "enum": ["bash", "sh", "zsh", "pwsh", "python"]
        },
        "environment": {
          "type": "array",
          "items": { "type": "string" }
        },
        "network": { "type": "boolean" },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "working_directory": { "type": "string" }
      }
    },

    "toolRequirement": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "min_version": { "type": "string" },
        "check_command": { "type": "string" },
        "optional": {
          "type": "boolean",
          "default": false
        }
      }
    },

    "consequenceExecution": {
      "type": "object",
      "additionalProperties": false,
      "description": "Runtime execution context for consequence types",
      "properties": {
        "runtime": {
          "type": "string",
          "enum": ["bash", "python", "node"]
        },
        "working_directory": { "type": "string" },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "timeout": { "type": "integer", "minimum": 1 },
            "max_memory": { "type": "string", "pattern": "^\\d+[KMGT]?$" },
            "max_output": { "type": "string", "pattern": "^\\d+[KMGT]?$" }
          }
        }
      }
    },

    "provides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/outputDeclaration" }
        }
      }
    },

    "outputDeclaration": {
      "type": "object",
      "required": ["field", "type"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "number", "object", "array"]
        },
        "pattern": { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "alternative": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "condition": { "type": "string" },
        "fallback": { "type": "boolean" },
        "effect": { "type": "string" },
        "error": { "type": "string" }
      }
    },

    "script": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "entrypoint": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "consequenceExample": {
      "type": "object",
      "required": ["title", "yaml"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "yaml": { "type": "string" },
        "state_before": { "type": "object" },
        "state_after": { "type": "object" }
      }
    },

    "preconditionFile": {
      "type": "object",
      "required": ["schema_version", "category", "description", "preconditions"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "$ref": "../common.json#/$defs/semver_short" },
        "category": { "$ref": "../common.json#/$defs/category_path" },
        "description": { "type": "string" },
        "preconditions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/precondition" }
        }
      }
    },

    "precondition": {
      "type": "object",
      "required": ["category", "description", "parameters", "evaluation"],
      "additionalProperties": false,
      "properties": {
        "category": { "$ref": "../common.json#/$defs/category_path" },
        "description": { "$ref": "#/$defs/typeDescription" },
        "parameters": {
          "type": "array",
          "items": { "$ref": "../common.json#/$defs/parameter" }
        },
        "evaluation": { "$ref": "#/$defs/evaluation" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/preconditionExample" }
        },
        "related": {
          "type": "array",
          "items": { "type": "string" }
        },
        "since": { "$ref": "../common.json#/$defs/semver" },
        "replaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "evaluation": {
      "type": "object",
      "required": ["effect"],
      "additionalProperties": false,
      "description": "Pure boolean evaluation (no side effects)",
      "properties": {
        "effect": { "type": "string" },
        "reads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "functions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "preconditionExample": {
      "type": "object",
      "required": ["title", "yaml"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "yaml": { "type": "string" },
        "context": {
          "type": "object",
          "properties": {
            "state": { "type": "object" },
            "files": { "type": "object" }
          }
        },
        "result": { "type": "boolean" }
      }
    },

    "nodeFile": {
      "type": "object",
      "required": ["schema_version", "category", "nodes"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "$ref": "../common.json#/$defs/semver_short" },
        "category": {
          "type": "string",
          "enum": ["core", "extensions"]
        },
        "nodes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/node" }
        }
      }
    },

    "node": {
      "type": "object",
      "required": ["description", "fields", "execution"],
      "additionalProperties": false,
      "properties": {
        "description": { "$ref": "#/$defs/typeDescription" },
        "deprecated": { "$ref": "#/$defs/deprecation" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "execution": { "$ref": "#/$defs/nodeExecution" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/nodeExample" }
        },
        "related": {
          "type": "array",
          "items": { "type": "string" }
        },
        "since": { "$ref": "../common.json#/$defs/semver" },
        "audit_since": { "$ref": "../common.json#/$defs/semver" },
        "deprecated_since": { "$ref": "../common.json#/$defs/semver" }
      }
    },

    "deprecation": {
      "type": "object",
      "required": ["since", "replacement", "reason"],
      "additionalProperties": false,
      "properties": {
        "since": { "$ref": "../common.json#/$defs/semver" },
        "replacement": { "type": "string" },
        "reason": { "type": "string" },
        "migration": { "type": "string" }
      }
    },

    "field": {
      "type": "object",
      "required": ["name", "type", "description"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "../common.json#/$defs/identifier" },
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "number", "array", "object", "precondition", "consequence", "node_reference", "any"]
        },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "value": { "description": "Constant value (for discriminator fields)" },
        "default": { "description": "Default value if not provided" },
        "min_items": { "type": "integer", "minimum": 0 },
        "max_items": { "type": "integer", "minimum": 1 },
        "max_length": { "type": "integer", "minimum": 1 },
        "pattern": { "type": "string" },
        "items": {
          "oneOf": [
            { "$ref": "#/$defs/field" },
            { "$ref": "#/$defs/inlineItemDefinition" },
            { "type": "string" }
          ]
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "additionalProperties": {
          "oneOf": [
            { "type": "array", "items": { "$ref": "#/$defs/field" } },
            { "$ref": "#/$defs/field" },
            { "$ref": "#/$defs/inlineItemDefinition" }
          ]
        },
        "interpolatable": { "type": "boolean", "default": true },
        "required_unless": { "type": "string" },
        "required_with": { "type": "string" },
        "reserved_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/reservedKey" }
        }
      }
    },

    "reservedKey": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "for": { "type": "string" }
      }
    },

    "inlineItemDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "number", "array", "object", "precondition", "consequence", "node_reference", "any"]
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "additional_properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "interpolatable": { "type": "boolean", "default": true }
      }
    },

    "nodeExecution": {
      "type": "object",
      "required": ["effect"],
      "additionalProperties": false,
      "description": "How the node executes (may have side effects)",
      "properties": {
        "effect": { "type": "string" },
        "state_reads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "state_writes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "nodeExample": {
      "type": "object",
      "required": ["title", "yaml"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "yaml": { "type": "string" },
        "explanation": { "type": "string" }
      }
    },

    "typeDescription": {
      "type": "object",
      "required": ["brief"],
      "additionalProperties": false,
      "properties": {
        "brief": {
          "type": "string",
          "maxLength": 100
        },
        "detail": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

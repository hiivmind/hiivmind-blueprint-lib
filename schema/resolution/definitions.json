{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hiivmind/hiivmind-blueprint-lib/main/schema/resolution/definitions.json",
  "$comment": "Schema for .hiivmind/blueprint/definitions.yaml — centralized per-repo type definitions",
  "title": "Blueprint Type Definitions",
  "description": "Centralized type definitions for a repo's workflows. Combines nodes, consequences, and preconditions in a single local file.",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "object",
      "description": "Node type definitions (action, conditional, user_prompt)",
      "additionalProperties": {
        "$ref": "#/$defs/nodeDefinition"
      }
    },
    "consequences": {
      "type": "object",
      "description": "Consequence type definitions (operations workflows can execute)",
      "additionalProperties": {
        "$ref": "#/$defs/consequenceDefinition"
      }
    },
    "preconditions": {
      "type": "object",
      "description": "Precondition type definitions (conditions workflows can check)",
      "additionalProperties": {
        "$ref": "#/$defs/preconditionDefinition"
      }
    }
  },
  "$defs": {
    "nodeDefinition": {
      "type": "object",
      "required": ["description", "execution"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "What this node type does"
        },
        "execution": {
          "$ref": "#/$defs/effectBlock"
        }
      }
    },
    "consequenceDefinition": {
      "type": "object",
      "required": ["description", "payload"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "What this consequence type does"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "payload": {
          "type": "object",
          "required": ["kind", "effect"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["state_mutation", "tool_call", "computation", "side_effect", "composite"]
            },
            "effect": {
              "type": "string",
              "description": "Pseudocode the LLM interprets to execute this consequence"
            },
            "tool": {
              "type": ["string", "null"],
              "description": "Claude tool name (for tool_call kind)"
            }
          }
        }
      }
    },
    "preconditionDefinition": {
      "type": "object",
      "required": ["description", "evaluation"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "What this precondition checks"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "evaluation": {
          "$ref": "#/$defs/effectBlock"
        }
      }
    },
    "effectBlock": {
      "type": "object",
      "required": ["effect"],
      "additionalProperties": false,
      "properties": {
        "effect": {
          "type": "string",
          "description": "Pseudocode the LLM interprets"
        }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name"
        },
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "number", "object", "array", "any"]
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "description": "Default value if not provided"
        },
        "description": {
          "type": "string"
        },
        "enum": {
          "type": "array",
          "description": "Allowed values"
        }
      }
    }
  }
}
